{
  "name": "hicm-hub",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler pages deploy dist",
    "cf:db:create": "wrangler d1 create hicm-hub-db",
    "cf:db:migrate": "wrangler d1 migrations apply hicm-hub-db",
    "cf:r2:create": "wrangler r2 bucket create hicm-hub-uploads",
    "cf:analysis:deploy": "wrangler deploy --config wrangler.analysis.toml",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "fflate": "^0.8.2",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "unpdf": "^1.0.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "vite": "^6.0.3",
    "vitest": "^3.2.4",
    "wrangler": "^4.110.0"
  }
}
